DATABASE_URL=postgresql://postgres:postgres@localhost:5432/haizu
BETTER_AUTH_SECRET=change-me-to-a-random-32-char-string
BETTER_AUTH_URL=http://localhost:3001
APP_ENV=local
WEB_ORIGIN=http://localhost:3000

# Email sending adapter.
# `console` = console output (default; does not actually send).
# `smtp` = SMTP sending. Uses Mailpit locally (check at http://localhost:8025 after running `docker compose up`).
EMAIL_DRIVER=console
# Used when EMAIL_DRIVER=smtp
SMTP_HOST=localhost
SMTP_PORT=1025
# SMTP_USER=
# SMTP_PASS=
SMTP_FROM=haizu <no-reply@haizu.local>

# File storage adapter. 'local' = local disk (default).
# For production, implement and swap in a FileStorage class
STORAGE_DRIVER=local
