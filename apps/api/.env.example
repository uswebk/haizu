DATABASE_URL=postgresql://postgres:postgres@localhost:5432/haizu
BETTER_AUTH_SECRET=change-me-to-a-random-32-char-string
BETTER_AUTH_URL=http://localhost:3001
APP_ENV=local
WEB_ORIGIN=http://localhost:3000

# メール送信アダプタ。console = コンソール出力（デフォルト、実送信しない）。
# smtp = SMTP 送信。ローカルは Mailpit（docker compose up 後、http://localhost:8025 で確認）、
# 本番は実 SMTP に SMTP_* を向ける。
EMAIL_DRIVER=console
# EMAIL_DRIVER=smtp のとき使用（下記は Mailpit 向けの既定値）
SMTP_HOST=localhost
SMTP_PORT=1025
# SMTP_USER=
# SMTP_PASS=
SMTP_FROM=haizu <no-reply@haizu.local>

# ファイル保存アダプタ。local = ローカルディスク（デフォルト）。
# 本番は FileStorage を実装して差し替える（src/storage/ 参照）。
STORAGE_DRIVER=local
