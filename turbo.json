{
    "$schema": "https://turbo.build/schema.json",
    "tasks": { 
      "build": {
        "dependsOn": ["^build"],                                                 
        "outputs": [".output/**", "dist/**"]                                      
      },
      "dev": {
        "cache": false,
        "persistent": true
      },
      "typecheck": {
        "dependsOn": ["^build"]                                                  
      },
      "db:generate": {
        "cache": false
      },
      "db:migrate": {
        "cache": false                                                            
      }
    }
  }
